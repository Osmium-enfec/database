# Application Configuration
ENVIRONMENT=development
APP_NAME=content-review-api
DEBUG=true

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=content_review
DB_SSLMODE=disable
DB_MAX_CONN=25

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production-to-something-random
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production-to-something-random
JWT_EXPIRY_HOURS=720

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
