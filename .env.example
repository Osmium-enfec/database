# Application Configuration
ENVIRONMENT=production
APP_NAME=content-review-api
DEBUG=false

# Database Configuration
# For Render: Set DATABASE_URL environment variable in Render dashboard (automatically provided by Postgres service)
# For local development: Use individual DB_* variables
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=content_review
DB_SSLMODE=disable
DB_MAX_CONN=25

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production-to-something-random-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production-to-something-random-min-32-chars
JWT_EXPIRY_HOURS=720

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# Render Deployment Notes:
# 1. Add this as "Web Service" (NOT Static Site)
# 2. Add Postgres service separately - Render will provide DATABASE_URL automatically
# 3. Set environment variables in Render dashboard:
#    - JWT_SECRET (generate a random 32+ char string)
#    - JWT_REFRESH_SECRET (generate a random 32+ char string)
# 4. Render will automatically provide DATABASE_URL from the connected Postgres service
